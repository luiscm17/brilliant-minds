# ── Azure AI Foundry / Agent Framework ──────────────────────────────────────
AI_PROJECT_ENDPOINT=<your-ai-project-endpoint>
AI_MODEL_DEPLOYMENT_NAME=gpt-4o-mini
AI_PROJECT_RESOURCE_ID=<your-ai-project-resource-id>
AI_PROJECT_CONNECTION_NAME=rag-mcp-connection

# ── Azure OpenAI (embeddings + completions) ──────────────────────────────────
OPENAI_ENDPOINT=<your-openai-endpoint>
OPENAI_API_KEY=<your-openai-api-key>
OPENAI_EMBEDDING_MODEL=text-embedding-ada-002

# ── JWT Authentication ───────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ── Azure Blob Storage ───────────────────────────────────────────────────────
AZURE_STORAGE_CONNECTION_STRING=<your-storage-connection-string>
AZURE_STORAGE_CONTAINER=documents

# ── Azure Cosmos DB ──────────────────────────────────────────────────────────
COSMOS_ENDPOINT=<your-cosmos-endpoint>
COSMOS_KEY=<your-cosmos-key>
COSMOS_DATABASE=docsimplify
COSMOS_USERS_CONTAINER=users
COSMOS_DOCUMENTS_CONTAINER=documents
COSMOS_CHATS_CONTAINER=chats

# ── Azure AI Search (RAG) ────────────────────────────────────────────────────
AZURE_SEARCH_ENDPOINT=<your-search-endpoint>
AZURE_SEARCH_KEY=<your-search-key>
AZURE_SEARCH_INDEX=documents-index
AGENTIC_RAG_ENABLED=false
KNOWLEDGE_SOURCE_NAME=docsimplify-knowledge-source
KNOWLEDGE_SOURCE_DESCRIPTION=Knowledge source built from uploaded DocSimplify documents
KNOWLEDGE_BASE_NAME=docsimplify-knowledge-base
KNOWLEDGE_BASE_DESCRIPTION=Agentic retrieval knowledge base for DocSimplify
KNOWLEDGE_BASE_ANSWER_INSTRUCTIONS=Answer in Spanish when the user writes in Spanish, keep the tone calm, and cite document context when available.
KNOWLEDGE_BASE_RETRIEVAL_INSTRUCTIONS=Prefer uploaded user documents, decompose complex questions into smaller subqueries, and prioritize accessible explanations.
LAYOUT_RAG_ENABLED=false
LAYOUT_RAG_INDEX_NAME=documents-layout-rag-v2
LAYOUT_RAG_DATASOURCE_NAME=documents-layout-rag-v2-datasource
LAYOUT_RAG_SKILLSET_NAME=documents-layout-rag-v2-skillset
LAYOUT_RAG_INDEXER_NAME=documents-layout-rag-v2-indexer
LAYOUT_RAG_MAX_CHUNK_LENGTH=2000
LAYOUT_RAG_OVERLAP_LENGTH=200
LAYOUT_RAG_ENABLE_IMAGE_REFERENCES=true
LAYOUT_RAG_CONTENT_FIELD=content
LAYOUT_RAG_VECTOR_FIELD=content_vector
LAYOUT_RAG_TITLE_FIELD=document_title
LAYOUT_RAG_PATH_FIELD=metadata_storage_path
LAYOUT_RAG_PAGE_FIELD=page_number

# ── Azure Document Intelligence ──────────────────────────────────────────────
DOCUMENT_INTELLIGENCE_ENDPOINT=<your-doc-intelligence-endpoint>
DOCUMENT_INTELLIGENCE_KEY=<your-doc-intelligence-key>

# ── General ──────────────────────────────────────────────────────────────────
ENVIRONMENT=development
